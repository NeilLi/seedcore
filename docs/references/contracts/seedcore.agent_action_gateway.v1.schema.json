    "AgentActionClosureResponse": {
      "additionalProperties": false,
      "properties": {
        "accepted_at": {
          "format": "date-time",
          "title": "Accepted At",
          "type": "string"
        },
        "closure_id": {
          "title": "Closure Id",
          "type": "string"
        },
        "contract_version": {
          "const": "seedcore.agent_action_gateway.v1",
