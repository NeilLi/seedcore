      "additionalProperties": false,
      "properties": {
        "closed_at": {
          "format": "date-time",
          "title": "Closed At",
          "type": "string"
        },
        "closure_id": {
          "title": "Closure Id",
          "type": "string"
        },
        "contract_version": {
          "const": "seedcore.agent_action_gateway.v1",
          "default": "seedcore.agent_action_gateway.v1",
          "title": "Contract Version",
          "type": "string"
        },
        "evidence_bundle_id": {
          "title": "Evidence Bundle Id",
          "type": "string"
        },
        "forensic_block": {
          "$ref": "#/$defs/AgentActionForensicBlock"
