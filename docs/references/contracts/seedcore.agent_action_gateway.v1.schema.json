        "idempotency_key": {
          "title": "Idempotency Key",
          "type": "string"
        },
        "node_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Node Id"
        },
        "outcome": {
          "default": "completed",
          "enum": [
            "completed",
            "quarantined",
            "failed"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "summary": {
          "additionalProperties": true,
          "title": "Summary",
          "type": "object"
        },
        "transition_receipt_ids": {
          "items": {
            "type": "string"
          },
          "title": "Transition Receipt Ids",
          "type": "array"
        }
      },
      "required": [
        "request_id",
        "closure_id",
        "idempotency_key",
        "closed_at",
        "evidence_bundle_id",
        "forensic_block"
