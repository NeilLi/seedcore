          "type": "string"
        },
        "forensic_block_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Forensic Block Id"
        },
        "linked_disposition": {
          "title": "Linked Disposition",
          "type": "string"
        },
        "next_actions": {
          "items": {
            "type": "string"
          },
          "title": "Next Actions",
          "type": "array"
        },
        "replay_status": {
          "default": "pending",
          "enum": [
            "pending",
            "ready"
          ],
          "title": "Replay Status",
          "type": "string"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "settlement_result": {
          "additionalProperties": true,
          "title": "Settlement Result",
          "type": "object"
        },
        "settlement_status": {
          "default": "pending",
          "enum": [
            "pending",
            "applied",
            "rejected"
          ],
          "title": "Settlement Status",
          "type": "string"
        },
        "status": {
          "const": "accepted_pending_settlement",
          "default": "accepted_pending_settlement",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "request_id",
        "closure_id",
        "accepted_at",
        "linked_disposition"
      ],
      "title": "AgentActionClosureResponse",
      "type": "object"
    },
