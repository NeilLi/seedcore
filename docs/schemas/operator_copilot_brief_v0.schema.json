{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedcore.local/schemas/operator_copilot_brief_v0.schema.json",
  "title": "Operator copilot brief (read-only MVP)",
  "description": "Stable JSON shape for deterministic stubs and LLM-backed copilot output. Version seedcore.operator_copilot_brief.v0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "case_id",
    "decision",
    "current_status",
    "why",
    "evidence_completeness",
    "verification_status",
    "anomalies",
    "recommended_action",
    "audit_note",
    "confidence",
    "uncertainty_notes",
    "one_line_summary",
    "operator_brief_bullets",
    "facts",
    "inferences",
    "citations",
    "generation_mode"
  ],
  "properties": {
    "contract_version": { "const": "seedcore.operator_copilot_brief.v0" },
    "case_id": { "type": "string" },
    "decision": { "type": "string" },
    "current_status": { "type": "string" },
    "why": { "type": "string" },
    "evidence_completeness": { "type": "string", "enum": ["complete", "partial", "gaps"] },
    "verification_status": { "type": "string" },
    "anomalies": { "type": "array", "items": { "type": "string" } },
    "recommended_action": { "type": "string" },
    "audit_note": { "type": "string" },
    "confidence": { "type": "string", "minLength": 1 },
    "uncertainty_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "one_line_summary": { "type": "string", "minLength": 1 },
    "operator_brief_bullets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 8
    },
    "facts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "inferences": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "value"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generation_mode": { "type": "string", "enum": ["deterministic", "llm"] }
  }
}
